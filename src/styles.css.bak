*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none}html,body,#app{margin:0;width:100%;height:100%;overflow:hidden;background:#08070d;color:#f5f2ff;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;touch-action:none}button,input,select{font:inherit}button{border:0;color:inherit;cursor:pointer}input,select{font-size:16px}.appLocked{position:fixed;inset:0;width:100vw;height:100dvh;overflow:hidden;background:radial-gradient(circle at 20% 0%,rgba(127,58,255,.22),transparent 38%),linear-gradient(180deg,#0f0d18,#08070d 55%,#050407);display:flex;flex-direction:column;padding:8px 8px 62px}.playPage{flex:1;min-height:0;display:flex;flex-direction:column;gap:8px;overflow:hidden}.miniTransport{flex:0 0 42px;border:1px solid rgba(255,255,255,.09);background:rgba(18,16,28,.9);border-radius:14px;display:grid;grid-template-columns:1fr auto auto 32px 32px 32px auto;align-items:center;gap:5px;padding:5px;box-shadow:0 10px 30px rgba(0,0,0,.25)}.brandSmall{display:flex;flex-direction:column;line-height:1}.brandSmall b{font-size:12px;letter-spacing:.12em}.brandSmall span{font-size:9px;color:#9d8dff;letter-spacing:.2em}.statusPill,.counter{font-size:10px;font-weight:900;color:#e9e2ff;background:#201b31;border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:6px 7px;white-space:nowrap}.counter{min-width:42px;text-align:center;color:#a7ffdf}.iconBtn{width:32px;height:32px;border-radius:10px;display:grid;place-items:center;background:#221d32;border:1px solid rgba(255,255,255,.1);font-weight:1000}.iconBtn.play{background:#8d5cff;color:#fff;box-shadow:0 0 22px rgba(141,92,255,.35)}.iconBtn.rec.active{background:#ff3b6b;color:#fff;box-shadow:0 0 20px rgba(255,59,107,.45)}.iconBtn.rec.armed{background:#ffb43d;color:#211400}.performanceArea{flex:1;min-height:0;display:flex;flex-direction:column;gap:8px;overflow:hidden}.playSequencer{flex:0 0 45%;min-height:150px;max-height:45%;border:1px solid rgba(255,255,255,.09);background:rgba(16,14,24,.88);border-radius:18px;padding:8px;display:grid;grid-template-rows:22px 16px 1fr;overflow:hidden}.seqHeader{display:flex;justify-content:space-between;align-items:center;font-weight:900;letter-spacing:.08em}.seqHeader span{font-size:11px}.seqHeader small{font-size:9px;color:#a99eff;text-transform:uppercase}.barNumbers{position:relative;height:16px;margin-left:91px;color:#80779b;font-size:10px}.barNumbers span{position:absolute;top:0;transform:translateX(-2px)}.seqRows{min-height:0;overflow:auto;display:flex;flex-direction:column;gap:4px;padding-right:2px;touch-action:none;scrollbar-width:none;overscroll-behavior:contain;contain:content}.seqRows::-webkit-scrollbar{display:none}.seqRow{display:grid;grid-template-columns:92px 1fr;gap:6px;min-height:25px;width:max-content;min-width:100%}.rowName{height:25px;border-radius:8px;background:#171320;border:1px solid rgba(255,255,255,.07);display:grid;grid-template-columns:8px 18px 1fr;align-items:center;gap:4px;text-align:left;padding:3px 5px;overflow:hidden}.rowName.editing{border-color:#ff3b9a;box-shadow:0 0 0 1px rgba(255,59,154,.65),0 0 18px rgba(255,59,154,.18)}.rowName i{height:16px;border-radius:999px}.rowName b{font-size:10px;color:#958aff}.rowName span{font-size:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#ddd7ff}.red{background:#ff3b6b}.orange{background:#ff8b3d}.yellow{background:#ffd23d}.green{background:#54e66b}.teal{background:#38ffd2}.blue{background:#44a7ff}.purple{background:#9d5cff}.pink{background:#ff5cbb}.gray{background:#83808e}.stepGrid{display:grid;gap:3px;min-width:420px}.step{width:18px;height:25px;border-radius:6px;background:#181420;border:1px solid rgba(255,255,255,.06);contain:layout paint;touch-action:none}.step.beat{background:#201a2e}.step.barStep{box-shadow:inset 2px 0 0 rgba(255,255,255,.18)}.step.hit{background:linear-gradient(180deg,#b18cff,#744cff);box-shadow:0 0 10px rgba(141,92,255,.5)}.step.now{outline:2px solid #a7ffdf;outline-offset:-2px}.bottomArea{flex:1 1 55%;min-height:210px;overflow:hidden;display:flex}.mpcOnly,.trackEditor.fixedPadEditor{width:100%;height:100%;min-height:0;overflow:hidden;visibility:visible;opacity:1}.mpcOnly{border:1px solid rgba(255,255,255,.09);background:rgba(13,11,19,.92);border-radius:20px;padding:10px;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));grid-template-rows:repeat(4,minmax(0,1fr));gap:10px;touch-action:none}.mpcPad{position:relative;border-radius:18px;background:linear-gradient(180deg,#242031,#15121d);border:1px solid rgba(255,255,255,.12);box-shadow:inset 0 1px 0 rgba(255,255,255,.07),0 12px 26px rgba(0,0,0,.28);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;overflow:hidden;touch-action:none;min-height:0}.mpcPad:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(255,255,255,.15),transparent 45%);opacity:.7}.mpcPad span{position:absolute;top:8px;left:10px;color:#8d849d;font-size:11px;font-weight:900}.mpcPad b{position:relative;font-size:13px;line-height:1.05;letter-spacing:.06em;text-align:center}.mpcPad:active,.mpcPad.selected{transform:translateY(1px) scale(.985);box-shadow:0 0 24px rgba(141,92,255,.42),inset 0 0 0 2px rgba(255,255,255,.08)}.trackEditor.fixedPadEditor{border:1px solid rgba(255,255,255,.1);background:linear-gradient(180deg,rgba(24,20,36,.97),rgba(10,8,16,.97));border-radius:20px;padding:9px;display:grid;grid-template-rows:38px 18px 1fr;gap:7px;touch-action:none}.editorTop{display:grid;grid-template-columns:32px minmax(0,1fr) 42px 32px;align-items:center;gap:8px;height:38px}.backBtn,.closeBtn,.previewBtn{height:32px;border-radius:10px;background:#211b31;border:1px solid rgba(255,255,255,.1);font-weight:900}.backBtn,.closeBtn{font-size:24px;line-height:1}.previewBtn{font-size:11px;padding:0 10px;color:#fff}.editorTitle{min-width:0}.editorTitle small{display:block;font-size:10px;letter-spacing:.18em;color:#bdb2ff;font-weight:1000}.editorTitle b{display:flex;align-items:center;gap:8px;min-width:0;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.editorTitle i{width:10px;height:22px;border-radius:999px;display:inline-block;flex:0 0 auto}.editorHint{font-size:10px;letter-spacing:.08em;text-align:center;color:#8f86a8;text-transform:uppercase}#editorBody{min-height:0;overflow:hidden}.minimalEditorGrid{height:100%;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:repeat(4,minmax(0,1fr));gap:8px;overflow:hidden}.editorControl,.editorSelectRow,.editorActionRow{border:1px solid rgba(255,255,255,.1);background:rgba(7,6,12,.55);border-radius:14px;padding:8px;min-height:0}.editorControl{display:grid;grid-template-columns:1fr auto;grid-template-rows:auto 1fr;align-items:center;gap:4px 8px}.editorControl span,.editorSelectRow span{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:#b8aecf;font-weight:1000}.editorControl b{font-size:11px;color:#fff}.editorControl input[type=range]{grid-column:1/-1;width:100%;accent-color:#9d5cff}.editorControl.wide{grid-column:span 2}.editorSelectRow{display:grid;grid-template-columns:1fr;gap:5px}.editorSelectRow select{width:100%;min-height:36px;border:0;border-radius:10px;background:#15101f;color:#fff;padding:6px 8px}.editorActionRow{grid-column:span 2;display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.editorActionRow button{border-radius:11px;background:#211b31;border:1px solid rgba(255,255,255,.1);font-weight:1000;color:#ede8ff}.editorActionRow button.active{background:linear-gradient(180deg,#ff3b8a,#9836ff);color:#fff}.sampleEditorGrid{height:100%;display:grid;grid-template-rows:minmax(75px,1fr) 48px 48px 44px;gap:8px;overflow:hidden}.wavePanel{position:relative;border:1px solid rgba(255,255,255,.1);border-radius:14px;overflow:hidden;background:#15101f}.waveCanvas{width:100%;height:100%;display:block}.trimOverlay{position:absolute;inset:0;pointer-events:none}.trimOverlay span{position:absolute;top:0;bottom:0;width:2px;background:#a7ffdf;box-shadow:0 0 10px rgba(167,255,223,.8)}.sampleActions{grid-column:auto}.bottomNav{position:fixed;left:8px;right:8px;bottom:max(8px,env(safe-area-inset-bottom));height:48px;border-radius:16px;background:rgba(16,14,24,.96);border:1px solid rgba(255,255,255,.1);display:grid;grid-template-columns:repeat(3,1fr);gap:6px;padding:6px;z-index:20}.bottomNav button{border-radius:12px;background:transparent;color:#9087a7;font-weight:900;display:flex;align-items:center;justify-content:center}.bottomNav button.active{background:#8d5cff;color:white}.pageScroll{height:calc(100dvh - 70px);overflow:auto;touch-action:pan-y;padding:8px 6px 20px}.pageScroll h2{margin:6px 0 12px}.settingsGrid{display:grid;grid-template-columns:1fr;gap:10px}.settingsGrid label,.toggle,.selectedInfo,.search,.cat,.import,.projectPanel{border:1px solid rgba(255,255,255,.09);background:rgba(18,16,28,.88);border-radius:14px;padding:12px}.settingsGrid label{display:grid;gap:8px;color:#aba2be;font-size:12px;font-weight:900;text-transform:uppercase}.settingsGrid input,.settingsGrid select,.search input{width:100%;border:0;border-radius:10px;background:#0e0c15;color:white;padding:12px}.toggle{min-height:48px;display:flex;align-items:center;justify-content:center;gap:8px;font-weight:900}.toggle.on{background:#3d2b75;color:#fff;border-color:#8d5cff}.toggle.danger{color:#ff6a8c}.selectedInfo{margin-bottom:10px;color:#d7d0ef}.padSelectMini{display:grid;grid-template-columns:repeat(8,1fr);gap:6px;margin-bottom:10px}.padSelectMini button{height:34px;border-radius:10px;background:#201b31;color:#d7d0ef;font-weight:900}.padSelectMini button.active{background:#8d5cff;color:#fff}.import{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:10px;font-weight:900}.import input{display:none}.search{display:flex;align-items:center;gap:8px;margin-bottom:10px}.catBlock{margin-bottom:8px}.cat{width:100%;display:grid;grid-template-columns:22px 1fr auto;gap:8px;align-items:center;text-align:left;font-weight:900}.cat em{color:#9b90af;font-style:normal}.sampleList{display:grid;grid-template-columns:1fr;gap:6px;padding:8px}.sampleList button{border-radius:10px;background:#171320;border:1px solid rgba(255,255,255,.07);padding:10px;text-align:left;color:#e8e0ff}.bpmStepper{border:1px solid rgba(255,255,255,.09);background:rgba(18,16,28,.88);border-radius:14px;padding:12px;display:grid;grid-template-columns:1fr 46px 70px 46px;align-items:center;gap:8px}.bpmStepper span{color:#aba2be;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.bpmStepper b{min-height:42px;display:grid;place-items:center;background:#0e0c15;border-radius:12px;font-size:20px}.bpmStepper button{min-height:42px;border-radius:12px;background:#211b31;border:1px solid rgba(255,255,255,.1);font-size:22px;font-weight:1000}.voiceMeter{position:relative;overflow:hidden;min-height:48px;border:1px solid rgba(168,85,247,.28);background:rgba(168,85,247,.08);border-radius:14px;padding:10px 12px;display:flex;align-items:center;justify-content:space-between;gap:10px}.voiceMeter span,.voiceMeter b{position:relative;z-index:2}.voiceMeter span{color:#c9b9ff;font-size:12px;text-transform:uppercase;letter-spacing:.08em}.voiceMeter b{color:#fff}.voiceMeter em{position:absolute;left:0;top:0;bottom:0;background:linear-gradient(90deg,rgba(168,85,247,.35),rgba(236,72,153,.28));z-index:1;transition:width .12s linear}.projectPanel{grid-column:1/-1;display:grid;gap:10px;background:radial-gradient(circle at 20% 0%,rgba(141,92,255,.16),transparent 42%),rgba(18,16,28,.92);border-color:rgba(141,92,255,.22)}.projectPanelHeader{display:flex;align-items:center;justify-content:space-between;gap:10px}.projectPanelHeader b{font-size:13px;letter-spacing:.14em;text-transform:uppercase}.projectPanelHeader span{font-size:11px;color:#a99eff;font-weight:800}.projectActions{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}.projectActions button{min-height:42px;border-radius:12px;background:#211b31;border:1px solid rgba(255,255,255,.1);color:#ede8ff;font-weight:1000;font-size:12px}.projectActions button:first-child{background:linear-gradient(180deg,#8d5cff,#6e46e8);color:#fff}.projectActions button.danger{color:#ff6a8c;background:rgba(255,59,107,.08);border-color:rgba(255,59,107,.22)}.projectPanel small{color:#8f86a8;font-size:11px;line-height:1.35}.countOverlay{position:fixed;inset:0;z-index:50;display:grid;place-items:center;pointer-events:none;background:radial-gradient(circle,rgba(141,92,255,.24),transparent 36%)}.countOverlay b{font-size:clamp(76px,22vw,190px);line-height:.8;color:white;text-shadow:0 0 34px rgba(141,92,255,.95),0 0 80px rgba(255,59,107,.35);font-weight:1000;letter-spacing:-.08em}.countOverlay span{position:absolute;top:calc(50% + 82px);font-size:14px;font-weight:1000;letter-spacing:.22em;text-transform:uppercase;color:#a7ffdf;background:rgba(8,7,13,.72);border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:8px 14px}.toast{position:fixed;left:50%;bottom:72px;transform:translateX(-50%);background:#211b31;color:#fff;border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:10px 14px;font-weight:900;font-size:12px;z-index:100;box-shadow:0 12px 32px rgba(0,0,0,.35)}@media(max-height:720px){.playSequencer{flex-basis:40%;max-height:40%;min-height:132px}.bottomArea{min-height:170px}.mpcPad b{font-size:11px}.mpcPad span{top:6px;left:8px;font-size:10px}.minimalEditorGrid{gap:6px}.editorControl,.editorSelectRow,.editorActionRow{padding:7px;border-radius:12px}}@media(min-width:800px){.appLocked{max-width:1180px;margin:0 auto;left:50%;transform:translateX(-50%)}.playSequencer{flex-basis:48%;max-height:48%}.seqRow{grid-template-columns:140px 1fr}.barNumbers{margin-left:139px}.rowName span{font-size:11px}.pageScroll{max-width:760px;margin:0 auto}.settingsGrid{grid-template-columns:1fr 1fr}.projectActions{grid-template-columns:repeat(5,1fr)}}

/* Phase 2 safe additions: undo/redo + keyboard pad guide */
.phasePanel {
  border-color: rgba(167,255,223,.22);
  background:
    radial-gradient(circle at 15% 0%, rgba(167,255,223,.12), transparent 40%),
    rgba(18,16,28,.92);
}
.phaseActions {
  grid-template-columns: repeat(2, 1fr);
}
.phaseActions button:first-child {
  background: linear-gradient(180deg, #a7ffdf, #4ce8b6);
  color: #07110d;
}
.phaseActions button:nth-child(2) {
  background: linear-gradient(180deg, #8d5cff, #6e46e8);
  color: #fff;
}

/* Phase 3: chord player + chord sequencer */
.bottomNav{grid-template-columns:repeat(4,1fr)}
.chordsPage{height:calc(100dvh - 70px);overflow:auto;touch-action:pan-y;padding:8px 6px 20px}
.chordsPage h2{margin:6px 0 12px;font-size:20px;letter-spacing:.04em}
.chordTopPanel{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.chordTopPanel label{border:1px solid rgba(255,255,255,.09);background:rgba(18,16,28,.88);border-radius:14px;padding:12px;display:grid;gap:8px;color:#aba2be;font-size:12px;font-weight:900;text-transform:uppercase}
.chordTopPanel select{width:100%;border:0;border-radius:10px;background:#0e0c15;color:white;padding:12px;font-size:16px}
.chordPadGrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:10px}
.chordPad{min-height:74px;border-radius:18px;border:1px solid rgba(255,255,255,.12);background:linear-gradient(180deg,#242031,#15121d);box-shadow:inset 0 1px 0 rgba(255,255,255,.07),0 12px 26px rgba(0,0,0,.28);display:grid;place-items:center;gap:4px;padding:10px;text-align:center;position:relative;overflow:hidden}
.chordPad:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(255,255,255,.15),transparent 45%);opacity:.7}
.chordPad b,.chordPad span{position:relative}.chordPad b{font-size:24px;letter-spacing:.08em}.chordPad span{font-size:12px;color:#ebe5ff;font-weight:900}.chordPad.selected{transform:translateY(1px) scale(.985);box-shadow:0 0 24px rgba(141,92,255,.42),inset 0 0 0 2px rgba(255,255,255,.08)}
.chordSequencerPanel{border:1px solid rgba(255,255,255,.09);background:rgba(16,14,24,.88);border-radius:18px;padding:10px;margin-bottom:10px}
.chordSeqHeader{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:10px}.chordSeqHeader b{font-size:12px;letter-spacing:.14em;text-transform:uppercase}.chordSeqHeader span{font-size:10px;color:#a99eff;text-transform:uppercase;font-weight:900}
.chordSteps{display:grid;grid-template-columns:repeat(4,1fr);gap:7px}.chordStep{min-height:58px;border-radius:12px;background:#171320;border:1px solid rgba(255,255,255,.08);display:grid;grid-template-rows:auto 1fr auto;align-items:center;justify-items:center;padding:6px;gap:2px}.chordStep b{font-size:9px;color:#8f86a8}.chordStep span{font-size:17px;font-weight:1000;color:#d8ceff}.chordStep em{font-style:normal;font-size:9px;color:#8f86a8;max-width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.chordStep.filled{background:linear-gradient(180deg,rgba(141,92,255,.35),rgba(65,45,115,.38));border-color:rgba(177,140,255,.35)}.chordStep.now{outline:2px solid #a7ffdf;outline-offset:-2px;box-shadow:0 0 16px rgba(167,255,223,.24)}
.chordActions{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}.chordActions button{min-height:42px;border-radius:12px;background:#211b31;border:1px solid rgba(255,255,255,.1);font-weight:1000;color:#ede8ff}.chordActions button:first-child{background:linear-gradient(180deg,#8d5cff,#6e46e8);color:#fff}.chordHelp{font-size:12px;line-height:1.4;color:#9f95b8;margin:0 4px 12px}
@media(min-width:700px){.chordPadGrid{grid-template-columns:repeat(4,1fr)}.chordSteps{grid-template-columns:repeat(8,1fr)}}

/* Phase 4: chord MIDI grid uses the same idea as the drum grid */
.chordMidiPanel{
  overflow:hidden;
}
.chordBarNumbers{
  position:relative;
  height:18px;
  margin-left:118px;
  color:#80779b;
  font-size:10px;
  margin-bottom:4px;
}
.chordBarNumbers span{
  position:absolute;
  top:0;
  transform:translateX(-2px);
}
.chordGridRows{
  min-height:0;
  overflow:auto;
  display:flex;
  flex-direction:column;
  gap:5px;
  padding-right:2px;
  touch-action:pan-x pan-y;
  overscroll-behavior:contain;
  scrollbar-width:none;
}
.chordGridRows::-webkit-scrollbar{display:none;width:0;height:0}
.chordGridRow{
  display:grid;
  grid-template-columns:118px 1fr;
  gap:6px;
  min-height:30px;
  width:max-content;
  min-width:100%;
}
.chordRowName{
  height:30px;
  border-radius:9px;
  background:#171320;
  border:1px solid rgba(255,255,255,.07);
  display:grid;
  grid-template-columns:8px 42px 1fr;
  align-items:center;
  gap:5px;
  text-align:left;
  padding:4px 6px;
  overflow:hidden;
}
.chordRowName.selected{
  border-color:rgba(177,140,255,.65);
  box-shadow:0 0 14px rgba(141,92,255,.18);
}
.chordRowName i{height:18px;border-radius:999px}
.chordRowName b{font-size:10px;color:#d8ceff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.chordRowName span{font-size:9px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#938ba7}
.chordStepGrid{
  display:grid;
  gap:3px;
  min-width:420px;
}
.chordGridCell{
  height:30px;
  border-radius:7px;
  background:#181420;
  border:1px solid rgba(255,255,255,.06);
}
.chordGridCell.beat{background:#201a2e}
.chordGridCell.barStep{box-shadow:inset 2px 0 0 rgba(255,255,255,.18)}
.chordGridCell.hit{
  background:linear-gradient(180deg,#b18cff,#744cff);
  border-color:rgba(255,255,255,.18);
  box-shadow:0 0 10px rgba(141,92,255,.48);
}
.chordGridCell.now{
  outline:2px solid #a7ffdf;
  outline-offset:-2px;
}
.chordTheory{
  font-size:11px;
  line-height:1.45;
  color:#bdb3d7;
  margin:0 4px 8px;
  padding:10px;
  border-radius:14px;
  background:rgba(18,16,28,.68);
  border:1px solid rgba(255,255,255,.07);
}
@media(min-width:700px){
  .chordGridRow{grid-template-columns:150px 1fr}
  .chordBarNumbers{margin-left:150px}
}

/* Phase 5: play chords from the MPC drum pads */
.chordPadModePanel{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
  margin:0 0 10px;
}
.chordPadModePanel button{
  min-height:44px;
  border-radius:14px;
  background:#211b31;
  border:1px solid rgba(255,255,255,.1);
  color:#ede8ff;
  font-weight:1000;
  letter-spacing:.04em;
}
.chordPadModePanel button.active{
  background:linear-gradient(180deg,#8d5cff,#6e46e8);
  color:#fff;
  box-shadow:0 0 22px rgba(141,92,255,.35);
}
.mpcOnly.chordMpcMode{
  background:
    radial-gradient(circle at 50% 0%,rgba(141,92,255,.12),transparent 48%),
    rgba(13,11,19,.92);
}
.mpcPad.chordTrigger b{
  font-size:17px;
  line-height:1.05;
}
.mpcPad.chordTrigger em{
  display:block;
  margin-top:4px;
  font-style:normal;
  font-size:9px;
  letter-spacing:.02em;
  color:#eae4ff;
  opacity:.88;
  white-space:nowrap;
}
.mpcPad.chordTrigger:after{
  content:'CHORD';
  position:absolute;
  right:8px;
  bottom:7px;
  font-size:8px;
  font-weight:1000;
  letter-spacing:.12em;
  color:rgba(255,255,255,.32);
}

/* Phase 6: chord pads record editable MIDI notes */
.chordSelectedNotes{
  border:1px solid rgba(255,255,255,.08);
  background:rgba(7,6,12,.45);
  border-radius:12px;
  padding:8px 10px;
  margin:0 0 8px;
  color:#bdb3d7;
  font-size:11px;
  line-height:1.35;
}
.chordSelectedNotes b{color:#fff}
.midiNoteRow.rootPitch .midiPitchName{
  border-color:rgba(167,255,223,.24);
  background:rgba(167,255,223,.06);
}
.midiPitchName b{font-size:11px!important;color:#f5f2ff!important}
.midiPitchName span{font-size:9px!important;color:#8f86a8!important}
.chordNoteCell.hit{
  background:linear-gradient(180deg,#a7ffdf,#44cfa9);
  border-color:rgba(255,255,255,.28);
  box-shadow:0 0 12px rgba(167,255,223,.38);
}

/* Phase 7: fixed scale + chord instrument page */
.bottomNav{grid-template-columns:repeat(4,1fr)}
.chordsInstrumentPage .performanceArea{gap:8px;overflow:hidden}
.chordPianoRoll{grid-template-rows:22px auto auto auto 16px 1fr;flex-basis:48%;max-height:48%;min-height:190px}
.chordControlsStrip{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:5px;min-height:0;overflow:hidden}
.chordControlsStrip label,.synthMiniControls label{display:grid;gap:2px;color:#b8aecf;font-size:8px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
.chordControlsStrip select,.synthMiniControls select{width:100%;min-height:27px;border:0;border-radius:8px;background:#0e0c15;color:#fff;padding:3px 5px;font-size:11px;font-weight:900}
.chordOctButtons{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.chordOctButtons button,.progressionButtons button{border-radius:8px;background:#211b31;border:1px solid rgba(255,255,255,.1);font-size:10px;font-weight:1000;color:#ede8ff}
.progressionButtons{grid-column:1/-1;display:flex;gap:5px;overflow-x:auto;min-height:30px;scrollbar-width:none}.progressionButtons::-webkit-scrollbar{display:none}.progressionButtons button{flex:0 0 auto;padding:0 8px;min-height:28px}
.synthMiniControls{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:5px}.synthMiniControls input{width:100%;accent-color:#9d5cff}
.chordSelectedNotes{margin:0;padding:5px 8px;min-height:24px;border:1px solid rgba(255,255,255,.08);background:rgba(7,6,12,.45);border-radius:10px;font-size:10px;color:#cfc7e8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.chordSelectedNotes b{color:#fff}
.chordPianoRoll .chordBarNumbers{height:16px;margin-left:92px;color:#80779b;font-size:10px;position:relative}.chordPianoRoll .chordBarNumbers span{position:absolute;top:0;transform:translateX(-2px)}
.chordPianoRoll .chordGridRows{min-height:0;overflow:auto;display:flex;flex-direction:column;gap:3px;touch-action:none;scrollbar-width:none;overscroll-behavior:contain}.chordPianoRoll .chordGridRows::-webkit-scrollbar{display:none;width:0;height:0}
.chordGridRow{display:grid;grid-template-columns:92px 1fr;gap:6px;min-height:22px;width:max-content;min-width:100%}.chordRowName{height:22px;border-radius:8px;background:#171320;border:1px solid rgba(255,255,255,.07);display:grid;grid-template-columns:8px 38px 1fr;align-items:center;gap:4px;text-align:left;padding:3px 5px;overflow:hidden}.chordRowName i{height:14px;border-radius:999px}.chordRowName b{font-size:10px;color:#d8ceff}.chordRowName span{font-size:8px;color:#938ba7}.chordStepGrid{display:grid;gap:3px;min-width:420px}.chordGridCell{width:18px;height:22px;border-radius:6px;background:#181420;border:1px solid rgba(255,255,255,.06)}.chordGridCell.beat{background:#201a2e}.chordGridCell.barStep{box-shadow:inset 2px 0 0 rgba(255,255,255,.18)}.chordGridCell.hit{background:linear-gradient(180deg,#6a4eff,#3b256d);box-shadow:0 0 9px rgba(141,92,255,.35)}.chordGridCell.noteStart{background:linear-gradient(180deg,#b18cff,#744cff)}.chordGridCell.now{outline:2px solid #a7ffdf;outline-offset:-2px}
.chordInstrumentPads .mpcPad b{font-size:13px}.chordInstrumentPads .mpcPad em{font-style:normal;font-size:9px;color:#d8ceff;letter-spacing:.02em}.mpcPad.holding,.chordTrigger.holding{transform:translateY(1px) scale(.97);box-shadow:0 0 34px rgba(167,255,223,.38),inset 0 0 0 2px rgba(167,255,223,.22)}
@media(max-height:760px){.chordPianoRoll{flex-basis:50%;max-height:50%;min-height:178px}.chordControlsStrip{grid-template-columns:repeat(4,minmax(0,1fr));gap:4px}.chordControlsStrip select,.synthMiniControls select{min-height:24px;font-size:10px}.synthMiniControls{display:none}.chordSelectedNotes{font-size:9px;min-height:22px}.chordGridRow{min-height:20px}.chordGridCell{height:20px}.chordRowName{height:20px}.progressionButtons{min-height:26px}.progressionButtons button{min-height:24px}}
@media(min-width:800px){.chordGridRow{grid-template-columns:140px 1fr}.chordPianoRoll .chordBarNumbers{margin-left:140px}.chordControlsStrip{grid-template-columns:repeat(8,minmax(0,1fr))}.progressionButtons{grid-column:1/-1}}

/* Phase 8: fixed instrument view modes and clear controls */
.instrumentPage {
  height: calc(100dvh - 70px);
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.instrumentModeBar {
  flex: 0 0 38px;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6px;
  padding: 0 1px;
}
.instrumentModeBar button {
  border-radius: 12px;
  background: rgba(31, 25, 46, .92);
  border: 1px solid rgba(255,255,255,.09);
  color: #d9d0f5;
  font-size: 11px;
  font-weight: 1000;
  letter-spacing: .02em;
  min-width: 0;
}
.instrumentModeBar button.active {
  color: #fff;
  background: linear-gradient(180deg, #8d5cff, #6e46e8);
  box-shadow: 0 0 18px rgba(141, 92, 255, .28);
}
.instrumentModeBar button.danger {
  color: #ffb2c7;
  background: rgba(255, 59, 107, .08);
  border-color: rgba(255, 59, 107, .22);
}
.instrumentPage .performanceArea {
  flex: 1 1 auto;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow: hidden;
}
.instrumentPage.splitView .playSequencer {
  flex: 0 0 45%;
  min-height: 150px;
  max-height: 48%;
}
.instrumentPage.splitView.chordsInstrumentPage .playSequencer {
  flex: 0 0 52%;
  max-height: 56%;
}
.instrumentPage.splitView .bottomArea {
  flex: 1 1 auto;
  min-height: 170px;
  overflow: hidden;
  display: flex;
}
.instrumentPage.gridView .performanceArea {
  gap: 0;
}
.instrumentPage.gridView .playSequencer {
  flex: 1 1 auto !important;
  max-height: none !important;
  min-height: 0 !important;
  height: auto !important;
}
.instrumentPage.padsView .performanceArea {
  gap: 0;
}
.instrumentPage.padsView .bottomArea {
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
  display: flex;
}
.instrumentPage.padsView .mpcOnly,
.instrumentPage.padsView .editor,
.instrumentPage.padsView .trackEditor {
  height: 100%;
  min-height: 0;
}
.instrumentPage .bottomArea > * {
  width: 100%;
}
@media (max-height: 740px) {
  .instrumentModeBar { flex-basis: 34px; gap: 5px; }
  .instrumentModeBar button { font-size: 10px; border-radius: 10px; }
  .instrumentPage.splitView .playSequencer { flex-basis: 42%; min-height: 132px; }
  .instrumentPage.splitView.chordsInstrumentPage .playSequencer { flex-basis: 55%; }
}

/* Phase 9: fullscreen MIDI editing + safer pad/chord interaction */
.gridFullStrip{
  min-height:24px;
  display:flex;
  align-items:center;
  justify-content:center;
  border:1px solid rgba(255,255,255,.08);
  border-radius:10px;
  background:rgba(7,6,12,.52);
  color:#bdb2ff;
  font-size:10px;
  font-weight:1000;
  letter-spacing:.12em;
  text-transform:uppercase;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  padding:0 8px;
}
.instrumentPage.gridView .playSequencer.gridFullRoll{
  grid-template-rows:22px 24px 16px minmax(0,1fr) !important;
  padding:6px !important;
}
.instrumentPage.gridView .playSequencer.gridFullRoll .seqHeader span,
.instrumentPage.gridView .playSequencer.gridFullRoll .seqHeader small{
  font-size:9px;
}
.instrumentPage.gridView .chordPianoRoll.gridFullRoll{
  grid-template-rows:22px 24px 16px minmax(0,1fr) !important;
  flex:1 1 auto !important;
  max-height:none !important;
  min-height:0 !important;
}
.instrumentPage.gridView .chordControlsStrip,
.instrumentPage.gridView .synthMiniControls,
.instrumentPage.gridView .chordSelectedNotes{
  display:none !important;
}
.instrumentPage.gridView .chordGridRows,
.instrumentPage.gridView .seqRows{
  min-height:0 !important;
  height:100% !important;
  overflow:auto !important;
}
.instrumentPage.gridView .chordGridRow,
.instrumentPage.gridView .seqRow{
  min-height:24px;
}
.instrumentPage.gridView .chordGridCell,
.instrumentPage.gridView .step{
  height:24px;
}
.instrumentPage.gridView .chordRowName,
.instrumentPage.gridView .rowName{
  height:24px;
}
.instrumentPage.gridView .instrumentModeBar{
  flex-basis:30px;
}
.instrumentPage.gridView .instrumentModeBar button{
  font-size:10px;
  min-height:28px;
}
.chordTrigger.holding,
.mpcPad.chordTrigger.holding{
  transform:translateY(1px) scale(.965);
  box-shadow:0 0 36px rgba(167,255,223,.5), inset 0 0 0 2px rgba(167,255,223,.28) !important;
}

/* Phase 10: portrait-locked rotated fullscreen MIDI grids
   Grid Full now uses time vertically and lanes/notes across the top so more bars are visible in portrait. */
.instrumentPage.gridView .playSequencer.rotatedMidiRoll{
  display:grid !important;
  grid-template-rows:28px minmax(0,1fr) !important;
  flex:1 1 auto !important;
  max-height:none !important;
  min-height:0 !important;
  height:auto !important;
  padding:6px !important;
  overflow:hidden !important;
}
.rotatedMiniStrip{
  min-height:28px;
  display:flex;
  align-items:center;
  justify-content:center;
  border:1px solid rgba(255,255,255,.08);
  border-radius:11px;
  background:rgba(7,6,12,.58);
  color:#bdb2ff;
  font-size:10px;
  font-weight:1000;
  letter-spacing:.12em;
  text-transform:uppercase;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  padding:0 8px;
}
.rotatedGridScroller{
  min-height:0;
  height:100%;
  overflow:auto;
  touch-action:none;
  overscroll-behavior:contain;
  -webkit-overflow-scrolling:auto;
  scrollbar-width:none;
  border-radius:14px;
  background:rgba(7,6,12,.16);
}
.rotatedGridScroller::-webkit-scrollbar{display:none;width:0;height:0}
.rotatedTopLabels,
.rotatedGridRow{
  display:grid;
  gap:4px;
  width:max-content;
  min-width:100%;
}
.rotatedTopLabels{
  position:sticky;
  top:0;
  z-index:8;
  padding:0 0 5px;
  background:linear-gradient(180deg,rgba(15,13,24,.98),rgba(15,13,24,.82));
  backdrop-filter:blur(8px);
}
.rotatedGridRow{
  min-height:31px;
  margin-bottom:4px;
}
.rotatedCorner,
.rotatedTimeLabel,
.rotatedTopName{
  border:1px solid rgba(255,255,255,.09);
  background:rgba(23,19,32,.96);
  border-radius:9px;
  min-height:31px;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}
.rotatedCorner{
  position:sticky;
  left:0;
  z-index:10;
  color:#8f86a8;
  font-size:9px;
  font-weight:1000;
  letter-spacing:.08em;
}
.rotatedTimeLabel{
  position:sticky;
  left:0;
  z-index:6;
  flex-direction:column;
  gap:1px;
  background:#100d18;
}
.rotatedTimeLabel b{
  font-size:10px;
  color:#ede8ff;
  line-height:1;
}
.rotatedTimeLabel small{
  font-size:8px;
  color:#7f758f;
  line-height:1;
}
.rotatedTopName{
  position:relative;
  flex-direction:column;
  gap:1px;
  padding:4px 5px;
  text-align:center;
}
.rotatedTopName i{
  width:16px;
  height:4px;
  border-radius:999px;
  display:block;
  flex:0 0 auto;
}
.rotatedTopName b{
  font-size:10px;
  color:#fff;
  line-height:1;
  max-width:100%;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}
.rotatedTopName span{
  font-size:8px;
  color:#9d94ad;
  line-height:1;
  max-width:100%;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}
.rotatedTopName.editing{
  border-color:#ff3b9a;
  box-shadow:0 0 0 1px rgba(255,59,154,.5),0 0 14px rgba(255,59,154,.18);
}
.rotatedStep,
.rotatedGridRow .step,
.rotatedGridRow .chordGridCell{
  height:31px !important;
  min-height:31px !important;
  border-radius:9px !important;
  min-width:0;
}
.rotatedGridRow.barRow .rotatedTimeLabel{
  border-color:rgba(167,255,223,.24);
  color:#a7ffdf;
}
.rotatedGridRow.barRow .rotatedStep{
  box-shadow:inset 2px 0 0 rgba(167,255,223,.16);
}
.chordRotatedRoll .rotatedTopName.noteTop{
  min-width:48px;
}
.chordRotatedRoll .rotatedTopName.rootPitch{
  border-color:rgba(167,255,223,.22);
  background:rgba(25,35,38,.72);
}
.drumRotatedRoll .rotatedTopName{
  min-width:64px;
}

/* Keep browser/PWA portrait-oriented as much as mobile Safari allows. */
@media (orientation: landscape){
  .appLocked::after{
    content:'Rotate back to portrait for Pangea grid editing';
    position:fixed;
    inset:0;
    z-index:999;
    display:grid;
    place-items:center;
    text-align:center;
    padding:32px;
    background:#08070d;
    color:#f5f2ff;
    font-weight:1000;
    letter-spacing:.08em;
  }
}

/* Phase 11: chord-only rotated trigger grid + no text highlighting on chord pads */
.chordTrigger,
.chordTrigger *,
.chordMpcMode,
.chordMpcMode *{
  -webkit-user-select:none !important;
  user-select:none !important;
  -webkit-touch-callout:none !important;
  -webkit-tap-highlight-color:transparent !important;
}
.chordTrigger::selection,
.chordTrigger *::selection{
  background:transparent;
}
.chordTrigger{
  touch-action:none;
}
.chordTriggerCell.noteStart,
.chordTriggerCell.hit{
  background:linear-gradient(180deg,#a987ff,#6f4bff) !important;
  box-shadow:0 0 14px rgba(141,92,255,.55), inset 0 0 0 1px rgba(255,255,255,.1);
}
.chordTriggerTop{
  min-width:64px;
}
.chordTriggerTop b{
  font-size:12px;
}
.chordTriggerTop span{
  font-size:7px;
}

/* Phase 12: Keep Awake + Audio Recovery */
.wakePanel{border-color:rgba(167,255,223,.22)!important;background:radial-gradient(circle at 15% 0%,rgba(56,255,210,.12),transparent 42%),rgba(18,16,28,.92)!important}
.wakePanel .wakeStatus{color:#a7ffdf;font-weight:1000}
.projectActions button.activeWake{background:linear-gradient(180deg,#38ffd2,#8d5cff)!important;color:#070612!important;border-color:rgba(167,255,223,.42)!important}

/* Phase 13: Voice recorder */
.bottomNav{grid-template-columns:repeat(5,1fr)!important}
.bottomNav button{font-size:clamp(10px,2.8vw,14px);padding:0 2px}
.voicePage{height:calc(100dvh - 70px);max-height:calc(100dvh - 70px);overflow:hidden}
.voiceWorkspace{flex:1;min-height:0;display:grid;grid-template-rows:auto 1fr;gap:10px;overflow:hidden}
.voiceRecorderPanel,.voiceClipsPanel{border:1px solid rgba(255,255,255,.1);background:linear-gradient(180deg,rgba(24,20,36,.94),rgba(9,8,15,.96));border-radius:20px;padding:12px;overflow:hidden}
.voiceHeader,.voiceClipsHeader{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px}.voiceHeader b,.voiceClipsHeader b{display:block;font-size:13px;letter-spacing:.16em;text-transform:uppercase}.voiceHeader span,.voiceClipsHeader span{display:block;color:#a99eff;font-size:11px;font-weight:900;margin-top:3px}.voiceTimer{min-width:64px;text-align:center;background:#0e0c15;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:9px 10px;color:#a7ffdf;font-weight:1000;letter-spacing:.08em}.voiceRecordControls{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:8px}.voiceRecordControls button,.voiceClipActions button{min-height:42px;border-radius:13px;background:#211b31;border:1px solid rgba(255,255,255,.1);font-weight:1000;color:#ede8ff}.voiceRecordControls #voiceRecordBtn{background:linear-gradient(180deg,#8d5cff,#6d46e8);color:#fff}.voiceRecordControls #voiceRecordBtn.recording{background:linear-gradient(180deg,#ff3b6b,#a51f46);box-shadow:0 0 24px rgba(255,59,107,.35)}.voiceHint{margin:10px 0 0;color:#9d94b7;font-size:11px;line-height:1.35}.voiceClipsPanel{min-height:0;overflow:auto;touch-action:pan-y}.voiceClip{border:1px solid rgba(255,255,255,.08);background:rgba(7,6,12,.58);border-radius:16px;padding:10px;margin-bottom:10px;display:grid;gap:9px}.voiceClipInfo{display:flex;align-items:center;justify-content:space-between;gap:10px}.voiceClipInfo b{font-size:13px}.voiceClipInfo span{font-size:11px;color:#a99eff;font-weight:900;white-space:nowrap}.voiceClipActions{display:grid;grid-template-columns:repeat(4,1fr);gap:7px}.voiceClipActions button{min-height:34px;border-radius:10px;font-size:11px}.voiceClipActions button.active{background:linear-gradient(180deg,#38ffd2,#8d5cff);color:#070612}.voiceClipActions button.danger{color:#ff6a8c;background:rgba(255,59,107,.08);border-color:rgba(255,59,107,.2)}.voiceVolume{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:10px;color:#b8aecf;font-size:11px;font-weight:1000;text-transform:uppercase;letter-spacing:.08em}.voiceVolume input{accent-color:#9d5cff}.emptyVoice{min-height:180px;border:1px dashed rgba(255,255,255,.16);border-radius:18px;display:grid;place-items:center;text-align:center;color:#9d94b7}.emptyVoice b{display:block;color:#fff;margin-bottom:4px}.emptyVoice span{font-size:12px}
@media(max-height:720px){.voiceRecorderPanel,.voiceClipsPanel{padding:10px;border-radius:16px}.voiceRecordControls button{min-height:38px}.voiceHint{display:none}.voiceClip{padding:8px}.voiceClipActions button{min-height:32px}}

/* Phase 14: Loop-comp voice recorder + waveform layers + voice FX */
.voiceCompWorkspace{
  grid-template-rows:auto auto 1fr !important;
}
.voiceRecordControls #voiceRecordBtn.armed{
  background:linear-gradient(180deg,#ffb43d,#8d5cff);
  color:#090612;
  box-shadow:0 0 24px rgba(255,180,61,.34);
}
.voiceFxPanel{
  border:1px solid rgba(167,255,223,.16);
  background:radial-gradient(circle at 15% 0%,rgba(56,255,210,.10),transparent 42%),linear-gradient(180deg,rgba(24,20,36,.94),rgba(9,8,15,.96));
  border-radius:20px;
  padding:10px;
  overflow:hidden;
}
.voiceFxGrid{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:8px;
}
.voiceFxGrid label{
  min-width:0;
  display:grid;
  gap:5px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(7,6,12,.56);
  border-radius:12px;
  padding:8px;
  font-size:10px;
  color:#b8aecf;
  font-weight:1000;
  text-transform:uppercase;
  letter-spacing:.08em;
}
.voiceFxGrid label b{
  color:#a7ffdf;
  font-size:10px;
}
.voiceFxGrid input{accent-color:#9d5cff;width:100%}
.voiceWave{
  height:46px;
  display:flex;
  align-items:center;
  gap:2px;
  padding:7px 8px;
  border-radius:13px;
  background:linear-gradient(180deg,rgba(141,92,255,.10),rgba(7,6,12,.62));
  border:1px solid rgba(255,255,255,.08);
  overflow:hidden;
}
.voiceWave i{
  flex:1;
  max-width:5px;
  min-width:2px;
  border-radius:99px;
  background:linear-gradient(180deg,#a7ffdf,#8d5cff 55%,#ff3b9a);
  box-shadow:0 0 8px rgba(141,92,255,.26);
  opacity:.9;
}
.voiceClip.compOn{
  border-color:rgba(167,255,223,.18);
  box-shadow:0 0 0 1px rgba(167,255,223,.04),0 10px 24px rgba(0,0,0,.18);
}
.voiceClipActionsFive{
  grid-template-columns:repeat(5,1fr)!important;
}
.voiceClipActionsFive button{
  font-size:10px!important;
  padding:0 3px;
}
@media(max-height:760px){
  .voiceFxPanel{padding:8px;border-radius:16px}
  .voiceFxGrid{grid-template-columns:repeat(3,minmax(0,1fr));gap:6px}
  .voiceFxGrid label{padding:6px;border-radius:10px;font-size:9px}
  .voiceWave{height:36px;padding:5px 6px}
}

/* Phase 21: Voice sample slicer + dedicated MIDI slice grid */
.voiceSlicerPanel,
.slicerGridPanel {
  border: 1px solid rgba(168,85,247,.18);
  background: linear-gradient(180deg, rgba(22,18,32,.94), rgba(11,9,17,.94));
  border-radius: 18px;
  padding: 12px;
  display: grid;
  gap: 10px;
}

.slicerPanelHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.slicerPanelHeader b {
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
}

.slicerPanelHeader span,
.voiceSlicerPanel small {
  font-size: 10px;
  color: #9f95b8;
  line-height: 1.35;
}

.slicerControls {
  display: grid;
  grid-template-columns: 1.5fr repeat(3, .8fr);
  gap: 8px;
}

.slicerControls label {
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 8px;
  background: rgba(255,255,255,.035);
  display: grid;
  gap: 6px;
  color: #bfb6d9;
  font-size: 10px;
  font-weight: 900;
  text-transform: uppercase;
}

.slicerControls select {
  width: 100%;
  border: 0;
  border-radius: 10px;
  background: #0e0c15;
  color: white;
  padding: 9px 8px;
  font-size: 12px;
}

.slicerActions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.slicerActions button {
  min-height: 38px;
  border-radius: 12px;
  background: #211b31;
  border: 1px solid rgba(255,255,255,.1);
  color: #ede8ff;
  font-weight: 1000;
  font-size: 11px;
}

.slicerActions button:first-child {
  background: linear-gradient(180deg, #8d5cff, #6e46e8);
}

.sliceGridMatrix {
  display: grid;
  gap: 4px;
  overflow-x: auto;
  padding-bottom: 2px;
  -webkit-overflow-scrolling: touch;
}

.sliceGridRow {
  display: grid;
  grid-template-columns: 86px 1fr;
  align-items: center;
  gap: 5px;
}

.sliceRowLabel {
  height: 26px;
  border-radius: 8px;
  background: #171320;
  border: 1px solid rgba(255,255,255,.07);
  color: #bfb6d9;
  display: grid;
  grid-template-columns: 10px 1fr;
  align-items: center;
  gap: 5px;
  padding: 3px 6px;
  text-align: left;
  min-width: 0;
}

.sliceRowLabel i {
  width: 8px;
  height: 16px;
  border-radius: 999px;
}

.sliceRowLabel span {
  font-size: 9px;
  font-weight: 1000;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.sliceGridRow.selected .sliceRowLabel {
  border-color: rgba(168,85,247,.7);
  color: #fff;
}

.sliceSteps,
.sliceTimeline {
  display: grid;
  grid-template-columns: repeat(16, minmax(22px, 1fr));
  gap: 3px;
  min-width: 390px;
}

.sliceStep {
  height: 25px;
  border-radius: 5px;
  border: 1px solid rgba(255,255,255,.06);
  background: #181420;
}

.sliceStep:nth-child(4n+1) {
  box-shadow: inset 2px 0 0 rgba(255,255,255,.15);
}

.sliceStep.active {
  background: linear-gradient(180deg,#b18cff,#744cff);
  box-shadow: 0 0 9px rgba(141,92,255,.45);
}

.sliceStep.playhead {
  outline: 2px solid #a7ffdf;
  outline-offset: -2px;
}

.sliceTimeline {
  display: grid;
  grid-template-columns: 86px repeat(16, minmax(22px, 1fr));
  min-width: calc(86px + 390px);
  align-items: center;
}

.sliceTimeline b {
  text-align: center;
  color: #706884;
  font-size: 9px;
}

@media (max-width: 720px) {
  .slicerControls { grid-template-columns: 1fr 1fr; }
  .sliceGridRow { grid-template-columns: 72px 1fr; }
  .sliceTimeline { grid-template-columns: 72px repeat(16, minmax(22px, 1fr)); min-width: calc(72px + 390px); }
  .sliceRowLabel span { font-size: 8px; }
}
